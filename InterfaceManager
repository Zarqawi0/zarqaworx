        function tabObj:CreateDropdown(titleText, optionsList, defaultOption, isMultiSelect, callback, side)
            optionsList = optionsList or {}
            if type(isMultiSelect) == "function" then
                side = callback
                callback = isMultiSelect
                isMultiSelect = false
            end
            callback = callback or function() end
            local parentCol = getTargetParent(side)

            local isOpen = false
            local selectedValues = {}
            local searchQuery = ""

            if isMultiSelect then
                if type(defaultOption) == "table" then
                    for _, val in ipairs(defaultOption) do selectedValues[val] = true end
                end
            else
                local initialVal = defaultOption or optionsList[1]
                if initialVal then selectedValues[initialVal] = true end
            end

            local dropdownContainer = Instance.new("Frame")
            dropdownContainer.Size = UDim2.new(1, 0, 0, 38)
            dropdownContainer.BackgroundColor3 = Color3.fromRGB(24, 24, 30)
            dropdownContainer.ClipsDescendants = true
            dropdownContainer.Parent = parentCol

            local dCorner = Instance.new("UICorner")
            dCorner.CornerRadius = UDim.new(0, 5)
            dCorner.Parent = dropdownContainer

            local dStroke = Instance.new("UIStroke")
            dStroke.Color = Color3.fromRGB(35, 35, 45)
            dStroke.Thickness = 1
            dStroke.Parent = dropdownContainer

            local headerBtn = Instance.new("TextButton")
            headerBtn.Size = UDim2.new(1, 0, 0, 38)
            headerBtn.BackgroundTransparency = 1
            headerBtn.Text = ""
            headerBtn.ZIndex = 5
            headerBtn.Parent = dropdownContainer

            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(0.5, -8, 1, 0)
            label.Position = UDim2.new(0, 10, 0, 0)
            label.BackgroundTransparency = 1
            label.Font = Enum.Font.GothamMedium
            label.Text = titleText
            label.TextColor3 = Color3.fromRGB(210, 210, 220)
            label.TextSize = 12
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.ZIndex = 6
            label.Parent = headerBtn

            local selectedLabel = Instance.new("TextLabel")
            selectedLabel.Size = UDim2.new(0.5, -24, 1, 0)
            selectedLabel.Position = UDim2.new(0.5, 0, 0, 0)
            selectedLabel.BackgroundTransparency = 1
            selectedLabel.Font = Enum.Font.Gotham
            selectedLabel.TextColor3 = Window.AccentColor
            selectedLabel.TextSize = 11
            selectedLabel.TextXAlignment = Enum.TextXAlignment.Right
            selectedLabel.ZIndex = 6
            selectedLabel.Parent = headerBtn

            local arrowIcon = Instance.new("TextLabel")
            arrowIcon.Size = UDim2.new(0, 18, 1, 0)
            arrowIcon.Position = UDim2.new(1, -20, 0, 0)
            arrowIcon.BackgroundTransparency = 1
            arrowIcon.Font = Enum.Font.GothamBold
            arrowIcon.Text = "v"
            arrowIcon.TextColor3 = Color3.fromRGB(130, 130, 145)
            arrowIcon.TextSize = 11
            arrowIcon.ZIndex = 6
            arrowIcon.Parent = headerBtn

            local searchBoxFrame = Instance.new("Frame")
            searchBoxFrame.Size = UDim2.new(1, -12, 0, 26)
            searchBoxFrame.Position = UDim2.new(0, 6, 0, 40)
            searchBoxFrame.BackgroundColor3 = Color3.fromRGB(16, 16, 20)
            searchBoxFrame.ZIndex = 10
            searchBoxFrame.Parent = dropdownContainer

            local searchCorner = Instance.new("UICorner")
            searchCorner.CornerRadius = UDim.new(0, 4)
            searchCorner.Parent = searchBoxFrame

            local searchStroke = Instance.new("UIStroke")
            searchStroke.Color = Color3.fromRGB(35, 35, 45)
            searchStroke.Thickness = 1
            searchStroke.Parent = searchBoxFrame

            local searchInput = Instance.new("TextBox")
            searchInput.Size = UDim2.new(1, -12, 1, 0)
            searchInput.Position = UDim2.new(0, 6, 0, 0)
            searchInput.BackgroundTransparency = 1
            searchInput.Font = Enum.Font.Gotham
            searchInput.PlaceholderText = "Search..."
            searchInput.PlaceholderColor3 = Color3.fromRGB(90, 90, 105)
            searchInput.Text = ""
            searchInput.TextColor3 = Color3.fromRGB(230, 230, 240)
            searchInput.TextSize = 11
            searchInput.TextXAlignment = Enum.TextXAlignment.Left
            searchInput.ClearTextOnFocus = false
            searchInput.ZIndex = 11
            searchInput.Parent = searchBoxFrame

            local optionListFrame = Instance.new("Frame")
            optionListFrame.Size = UDim2.new(1, -12, 0, 0)
            optionListFrame.Position = UDim2.new(0, 6, 0, 72)
            optionListFrame.BackgroundTransparency = 1
            optionListFrame.ZIndex = 10
            optionListFrame.Parent = dropdownContainer

            local listLayout = Instance.new("UIListLayout")
            listLayout.SortOrder = Enum.SortOrder.LayoutOrder
            listLayout.Padding = UDim.new(0, 3)
            listLayout.Parent = optionListFrame

            local function updateHeaderLabel()
                if isMultiSelect then
                    local list = {}
                    for opt, isSel in pairs(selectedValues) do
                        if isSel then table.insert(list, tostring(opt)) end
                    end
                    selectedLabel.Text = (#list == 0) and "None" or table.concat(list, ", ")
                else
                    local current = "Select..."
                    for opt, isSel in pairs(selectedValues) do
                        if isSel then current = tostring(opt) break end
                    end
                    selectedLabel.Text = current
                end
            end

            local function updateContainerHeight()
                local listHeight = listLayout.AbsoluteContentSize.Y
                local targetHeight = isOpen and (78 + listHeight) or 38

                TweenService:Create(dropdownContainer, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                    Size = UDim2.new(1, 0, 0, targetHeight)
                }):Play()

                TweenService:Create(arrowIcon, TweenInfo.new(0.2), {
                    Rotation = isOpen and 180 or 0
                }):Play()
            end

            local function refreshList()
                for _, child in pairs(optionListFrame:GetChildren()) do
                    if child:IsA("TextButton") then child:Destroy() end
                end

                for idx, opt in ipairs(optionsList) do
                    local strOpt = tostring(opt)
                    if searchQuery == "" or string.find(string.lower(strOpt), string.lower(searchQuery), 1, true) then
                        local isSelected = selectedValues[opt] == true
                        local optBtn = Instance.new("TextButton")
                        optBtn.Size = UDim2.new(1, 0, 0, 24)
                        optBtn.BackgroundColor3 = isSelected and Color3.fromRGB(30, 30, 40) or Color3.fromRGB(18, 18, 22)
                        optBtn.Font = Enum.Font.Gotham
                        optBtn.Text = "   " .. (isSelected and "✓ " or "") .. strOpt
                        optBtn.TextColor3 = isSelected and Window.AccentColor or Color3.fromRGB(160, 160, 175)
                        optBtn.TextSize = 11
                        optBtn.TextXAlignment = Enum.TextXAlignment.Left
                        optBtn.LayoutOrder = idx
                        optBtn.ZIndex = 11
                        optBtn.Parent = optionListFrame

                        local oCorner = Instance.new("UICorner")
                        oCorner.CornerRadius = UDim.new(0, 4)
                        oCorner.Parent = optBtn

                        optBtn.MouseButton1Click:Connect(function()
                            if isMultiSelect then
                                selectedValues[opt] = not selectedValues[opt]
                                updateHeaderLabel()
                                refreshList()
                                updateContainerHeight()

                                local selectedTable = {}
                                for item, sel in pairs(selectedValues) do
                                    if sel then table.insert(selectedTable, item) end
                                end
                                pcall(callback, selectedTable)
                            else
                                selectedValues = {[opt] = true}
                                updateHeaderLabel()
                                refreshList()
                                updateContainerHeight()

                                pcall(callback, opt)
                            end
                        end)
                    end
                end
            end

            searchInput:GetPropertyChangedSignal("Text"):Connect(function()
                searchQuery = searchInput.Text
                refreshList()
                updateContainerHeight()
            end)

            updateHeaderLabel()
            refreshList()

            headerBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                updateContainerHeight()
            end)

            return dropdownContainer
        end

