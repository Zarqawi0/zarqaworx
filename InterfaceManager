            pCorner.Parent = paraFrame

            local pStroke = Instance.new("UIStroke")
            pStroke.Color = Color3.fromRGB(35, 35, 45)
            pStroke.Thickness = 1
            pStroke.Parent = paraFrame

            local titleLabel = Instance.new("TextLabel")
            titleLabel.Size = UDim2.new(1, -20, 0, 18)
            titleLabel.Position = UDim2.new(0, 10, 0, 8)
            titleLabel.BackgroundTransparency = 1
            titleLabel.Font = Enum.Font.GothamBold
            titleLabel.Text = titleText
            titleLabel.TextColor3 = Color3.fromRGB(230, 230, 240)
            titleLabel.TextSize = 12
            titleLabel.TextXAlignment = Enum.TextXAlignment.Left
            titleLabel.Parent = paraFrame

            local contentLabel = Instance.new("TextLabel")
            contentLabel.Size = UDim2.new(1, -20, 0, 0)
            contentLabel.Position = UDim2.new(0, 10, 0, 26)
            contentLabel.BackgroundTransparency = 1
            contentLabel.Font = Enum.Font.Gotham
            contentLabel.Text = contentText
            contentLabel.TextColor3 = Color3.fromRGB(140, 140, 155)
            contentLabel.TextSize = 11
            contentLabel.TextXAlignment = Enum.TextXAlignment.Left
            contentLabel.TextYAlignment = Enum.TextYAlignment.Top
            contentLabel.TextWrapped = true
            contentLabel.Parent = paraFrame

            local function resize()
                contentLabel.Size = UDim2.new(1, -20, 0, contentLabel.TextBounds.Y)
                paraFrame.Size = UDim2.new(1, 0, 0, contentLabel.TextBounds.Y + 34)
            end
            contentLabel:GetPropertyChangedSignal("TextBounds"):Connect(resize)
            task.spawn(resize)

            return paraFrame
        end

        function tabObj:CreateImageParagraph(titleText, contentText, assetId, side)
            local parentCol = getTargetParent(side)

            local paraFrame = Instance.new("Frame")
            paraFrame.Size = UDim2.new(1, 0, 0, 0)
            paraFrame.BackgroundColor3 = Color3.fromRGB(24, 24, 30)
            paraFrame.Parent = parentCol

            local pCorner = Instance.new("UICorner")
            pCorner.CornerRadius = UDim.new(0, 5)
            pCorner.Parent = paraFrame

            local pStroke = Instance.new("UIStroke")
            pStroke.Color = Color3.fromRGB(35, 35, 45)
            pStroke.Thickness = 1
            pStroke.Parent = paraFrame

            local iconImg = Instance.new("ImageLabel")
            iconImg.Size = UDim2.new(0, 26, 0, 26)
            iconImg.Position = UDim2.new(0, 8, 0, 8)
            iconImg.BackgroundTransparency = 1
            iconImg.Parent = paraFrame

            if type(assetId) == "number" or (type(assetId) == "string" and not string.find(assetId, "rbxassetid://")) then
                iconImg.Image = "rbxassetid://" .. tostring(assetId)
            else
                iconImg.Image = tostring(assetId)
            end

            local titleLabel = Instance.new("TextLabel")
            titleLabel.Size = UDim2.new(1, -46, 0, 18)
            titleLabel.Position = UDim2.new(0, 40, 0, 6)
            titleLabel.BackgroundTransparency = 1
            titleLabel.Font = Enum.Font.GothamBold
            titleLabel.Text = titleText
            titleLabel.TextColor3 = Color3.fromRGB(230, 230, 240)
            titleLabel.TextSize = 12
            titleLabel.TextXAlignment = Enum.TextXAlignment.Left
            titleLabel.Parent = paraFrame

            local contentLabel = Instance.new("TextLabel")
            contentLabel.Size = UDim2.new(1, -46, 0, 0)
            contentLabel.Position = UDim2.new(0, 40, 0, 24)
            contentLabel.BackgroundTransparency = 1
            contentLabel.Font = Enum.Font.Gotham
            contentLabel.Text = contentText
            contentLabel.TextColor3 = Color3.fromRGB(140, 140, 155)
            contentLabel.TextSize = 11
            contentLabel.TextXAlignment = Enum.TextXAlignment.Left
            contentLabel.TextYAlignment = Enum.TextYAlignment.Top
            contentLabel.TextWrapped = true
            contentLabel.Parent = paraFrame

            local function resize()
                local calculatedHeight = math.max(28, contentLabel.TextBounds.Y + 24)
                contentLabel.Size = UDim2.new(1, -46, 0, contentLabel.TextBounds.Y)
                paraFrame.Size = UDim2.new(1, 0, 0, calculatedHeight + 12)
            end
            contentLabel:GetPropertyChangedSignal("TextBounds"):Connect(resize)
            task.spawn(resize)

            return paraFrame
        end

        function tabObj:CreateSlider(titleText, minVal, maxVal, defaultVal, callback, side)
            callback = callback or function() end
            minVal = minVal or 0
            maxVal = maxVal or 100
            defaultVal = math.clamp(defaultVal or minVal, minVal, maxVal)

            local parentCol = getTargetParent(side)
            local currentVal = defaultVal

            local sliderContainer = Instance.new("Frame")
            sliderContainer.Size = UDim2.new(1, 0, 0, 42)
            sliderContainer.BackgroundColor3 = Color3.fromRGB(24, 24, 30)
            sliderContainer.Parent = parentCol

            local sCorner = Instance.new("UICorner")
            sCorner.CornerRadius = UDim.new(0, 5)
            sCorner.Parent = sliderContainer

            local sStroke = Instance.new("UIStroke")
            sStroke.Color = Color3.fromRGB(35, 35, 45)
            sStroke.Thickness = 1
            sStroke.Parent = sliderContainer

            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(0.6, -10, 0, 18)
            label.Position = UDim2.new(0, 10, 0, 5)
            label.BackgroundTransparency = 1
            label.Font = Enum.Font.GothamMedium
            label.Text = titleText
            label.TextColor3 = Color3.fromRGB(210, 210, 220)
            label.TextSize = 12
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.Parent = sliderContainer

            local valLabel = Instance.new("TextLabel")
            valLabel.Size = UDim2.new(0.4, -10, 0, 18)
            valLabel.Position = UDim2.new(0.6, 0, 0, 5)
            valLabel.BackgroundTransparency = 1
            valLabel.Font = Enum.Font.Gotham
            valLabel.Text = tostring(currentVal)
            valLabel.TextColor3 = Window.AccentColor
            valLabel.TextSize = 11
            valLabel.TextXAlignment = Enum.TextXAlignment.Right
            valLabel.Parent = sliderContainer

            local sliderBar = Instance.new("Frame")
            sliderBar.Size = UDim2.new(1, -20, 0, 5)
            sliderBar.Position = UDim2.new(0, 10, 0, 28)
            sliderBar.BackgroundColor3 = Color3.fromRGB(16, 16, 20)
            sliderBar.Parent = sliderContainer

            local barCorner = Instance.new("UICorner")
            barCorner.CornerRadius = UDim.new(1, 0)
            barCorner.Parent = sliderBar

            local fill = Instance.new("Frame")
            fill.Size = UDim2.new((currentVal - minVal) / (maxVal - minVal), 0, 1, 0)
            fill.BackgroundColor3 = Window.AccentColor
            fill.Parent = sliderBar

            local fillCorner = Instance.new("UICorner")
            fillCorner.CornerRadius = UDim.new(1, 0)
            fillCorner.Parent = fill

            local isDragging = false

            local function updateValue(input)
                local posX = math.clamp(input.Position.X - sliderBar.AbsolutePosition.X, 0, sliderBar.AbsoluteSize.X)
                local percent = posX / sliderBar.AbsoluteSize.X
                currentVal = math.floor(minVal + (maxVal - minVal) * percent)

                valLabel.Text = tostring(currentVal)
                fill.Size = UDim2.new(percent, 0, 1, 0)
                pcall(callback, currentVal)
            end

            sliderBar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    isDragging = true
                    updateValue(input)
                end
            end)

            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    isDragging = false
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    updateValue(input)
                end
            end)

            return sliderContainer
        end

        return tabObj
    end

    return Window
end

return Library
