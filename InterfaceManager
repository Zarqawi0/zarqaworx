local InterfaceManager = {}
InterfaceManager.__index = InterfaceManager

-- Services
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")

-- Color Palette
local COLORS = {
	Background = Color3.fromRGB(15, 15, 15),
	Sidebar = Color3.fromRGB(20, 20, 20),
	CardBackground = Color3.fromRGB(24, 24, 24),
	CardHeader = Color3.fromRGB(28, 28, 28),
	InputBackground = Color3.fromRGB(32, 32, 32),
	Accent = Color3.fromRGB(255, 120, 0),
	TextPrimary = Color3.fromRGB(255, 255, 255),
	TextMuted = Color3.fromRGB(150, 150, 150),
	ToggleOff = Color3.fromRGB(50, 50, 50)
}

function InterfaceManager.CreateWindow(title, subtitle, keyStatus)
	local self = setmetatable({}, InterfaceManager)

	-- Parent Container Setup
	local ParentContainer
	if gethui then
		ParentContainer = gethui()
	elseif syn and syn.protect_gui then
		local Folder = Instance.new("Folder")
		syn.protect_gui(Folder)
		Folder.Parent = CoreGui
		ParentContainer = Folder
	else
		ParentContainer = CoreGui:FindFirstChild("RobloxGui") or CoreGui or Players.LocalPlayer:WaitForChild("PlayerGui")
	end

	if ParentContainer:FindFirstChild("BigFrootUI") then
		ParentContainer.BigFrootUI:Destroy()
	end

	-- ScreenGui
	self.ScreenGui = Instance.new("ScreenGui")
	self.ScreenGui.Name = "BigFrootUI"
	self.ScreenGui.ResetOnSpawn = false
	self.ScreenGui.Parent = ParentContainer

	-- Main Window
	self.MainFrame = Instance.new("Frame")
	self.MainFrame.Name = "MainFrame"
	self.MainFrame.Size = UDim2.new(0, 680, 0, 440)
	self.MainFrame.Position = UDim2.new(0.5, -340, 0.5, -220)
	self.MainFrame.BackgroundColor3 = COLORS.Background
	self.MainFrame.BorderSizePixel = 0
	self.MainFrame.ClipsDescendants = true
	self.MainFrame.Active = true
	self.MainFrame.Draggable = true
	self.MainFrame.Parent = self.ScreenGui

	local MainCorner = Instance.new("UICorner")
	MainCorner.CornerRadius = UDim.new(0, 10)
	MainCorner.Parent = self.MainFrame

	-- Sidebar
	self.Sidebar = Instance.new("Frame")
	self.Sidebar.Size = UDim2.new(0, 170, 1, 0)
	self.Sidebar.BackgroundColor3 = COLORS.Sidebar
	self.Sidebar.BorderSizePixel = 0
	self.Sidebar.Parent = self.MainFrame

	-- Title
	local TitleFrame = Instance.new("Frame")
	TitleFrame.Size = UDim2.new(1, 0, 0, 55)
	TitleFrame.BackgroundTransparency = 1
	TitleFrame.Parent = self.Sidebar

	local MainTitle = Instance.new("TextLabel")
	MainTitle.Size = UDim2.new(1, -20, 0, 22)
	MainTitle.Position = UDim2.new(0, 15, 0, 10)
	MainTitle.BackgroundTransparency = 1
	MainTitle.Text = title or '<font color="#FF7A00">Big</font>Froot'
	MainTitle.RichText = true
	MainTitle.TextColor3 = COLORS.TextPrimary
	MainTitle.TextSize = 18
	MainTitle.Font = Enum.Font.GothamBold
	MainTitle.TextXAlignment = Enum.TextXAlignment.Left
	MainTitle.Parent = TitleFrame

	local SubTitle = Instance.new("TextLabel")
	SubTitle.Size = UDim2.new(1, -20, 0, 15)
	SubTitle.Position = UDim2.new(0, 15, 0, 32)
	SubTitle.BackgroundTransparency = 1
	SubTitle.Text = subtitle or "Grow a Garden 2"
	SubTitle.TextColor3 = COLORS.TextMuted
	SubTitle.TextSize = 11
	SubTitle.Font = Enum.Font.Gotham
	SubTitle.TextXAlignment = Enum.TextXAlignment.Left
	SubTitle.Parent = TitleFrame

	-- Sidebar Nav List
	self.SideNavList = Instance.new("ScrollingFrame")
	self.SideNavList.Size = UDim2.new(1, 0, 1, -95)
	self.SideNavList.Position = UDim2.new(0, 0, 0, 55)
	self.SideNavList.BackgroundTransparency = 1
	self.SideNavList.ScrollBarThickness = 2
	self.SideNavList.Parent = self.Sidebar

	local SideLayout = Instance.new("UIListLayout")
	SideLayout.Padding = UDim.new(0, 4)
	SideLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	SideLayout.Parent = self.SideNavList

	-- Sidebar Footer
	local SideFooter = Instance.new("Frame")
	SideFooter.Size = UDim2.new(1, 0, 0, 40)
	SideFooter.Position = UDim2.new(0, 0, 1, -40)
	SideFooter.BackgroundTransparency = 1
	SideFooter.Parent = self.Sidebar

	local KeyLabel = Instance.new("TextLabel")
	KeyLabel.Size = UDim2.new(1, -20, 1, 0)
	KeyLabel.Position = UDim2.new(0, 15, 0, 0)
	KeyLabel.BackgroundTransparency = 1
	KeyLabel.Text = keyStatus or "Lifetime key"
	KeyLabel.TextColor3 = COLORS.TextMuted
	KeyLabel.TextSize = 11
	KeyLabel.Font = Enum.Font.Gotham
	KeyLabel.TextXAlignment = Enum.TextXAlignment.Left
	KeyLabel.Parent = SideFooter

	-- Top Bar
	self.TopBar = Instance.new("Frame")
	self.TopBar.Size = UDim2.new(1, -170, 0, 45)
	self.TopBar.Position = UDim2.new(0, 170, 0, 0)
	self.TopBar.BackgroundTransparency = 1
	self.TopBar.Parent = self.MainFrame

	self.TopNavList = Instance.new("Frame")
	self.TopNavList.Size = UDim2.new(1, -40, 1, 0)
	self.TopNavList.BackgroundTransparency = 1
	self.TopNavList.Parent = self.TopBar

	local TopLayout = Instance.new("UIListLayout")
	TopLayout.FillDirection = Enum.FillDirection.Horizontal
	TopLayout.Padding = UDim.new(0, 6)
	TopLayout.VerticalAlignment = Enum.VerticalAlignment.Center
	TopLayout.Parent = self.TopNavList

	local TopPadding = Instance.new("UIPadding")
	TopPadding.PaddingLeft = UDim.new(0, 12)
	TopPadding.Parent = self.TopNavList

	-- Content Area
	self.ContentArea = Instance.new("ScrollingFrame")
	self.ContentArea.Size = UDim2.new(1, -180, 1, -75)
	self.ContentArea.Position = UDim2.new(0, 175, 0, 45)
	self.ContentArea.BackgroundTransparency = 1
	self.ContentArea.ScrollBarThickness = 3
	self.ContentArea.CanvasSize = UDim2.new(0, 0, 0, 500)
	self.ContentArea.Parent = self.MainFrame

	local ContentGrid = Instance.new("UIGridLayout")
	ContentGrid.CellSize = UDim2.new(0, 235, 0, 200)
	ContentGrid.CellPadding = UDim2.new(0, 10, 0, 10)
	ContentGrid.Parent = self.ContentArea

	-- Bottom Footer
	local BottomBar = Instance.new("Frame")
	BottomBar.Size = UDim2.new(1, -170, 0, 25)
	BottomBar.Position = UDim2.new(0, 170, 1, -25)
	BottomBar.BackgroundTransparency = 1
	BottomBar.Parent = self.MainFrame

	local VersionLabel = Instance.new("TextLabel")
	VersionLabel.Size = UDim2.new(1, -15, 1, 0)
	VersionLabel.BackgroundTransparency = 1
	VersionLabel.Text = "v1.3.9 | Free"
	VersionLabel.TextColor3 = COLORS.TextMuted
	VersionLabel.Font = Enum.Font.GothamBold
	VersionLabel.TextSize = 10
	VersionLabel.TextXAlignment = Enum.TextXAlignment.Right
	VersionLabel.Parent = BottomBar

	return self
end

--------------------------------------------------------------------------------
-- NAVIGATION METHODS
--------------------------------------------------------------------------------
function InterfaceManager:AddSidebarButton(name, isActive, callback)
	local Btn = Instance.new("TextButton")
	Btn.Size = UDim2.new(0, 150, 0, 32)
	Btn.BackgroundColor3 = isActive and COLORS.CardBackground or COLORS.Sidebar
	Btn.BackgroundTransparency = isActive and 0 or 1
	Btn.Text = "   " .. name
	Btn.TextColor3 = isActive and COLORS.TextPrimary or COLORS.TextMuted
	Btn.Font = Enum.Font.GothamMedium
	Btn.TextSize = 12
	Btn.TextXAlignment = Enum.TextXAlignment.Left
	Btn.Parent = self.SideNavList

	local BtnCorner = Instance.new("UICorner")
	BtnCorner.CornerRadius = UDim.new(0, 6)
	BtnCorner.Parent = Btn

	if callback then
		Btn.MouseButton1Click:Connect(callback)
	end
	return Btn
end

function InterfaceManager:AddSubTab(name, isActive, callback)
	local Tab = Instance.new("TextButton")
	Tab.Size = UDim2.new(0, 65, 0, 28)
	Tab.BackgroundColor3 = isActive and COLORS.CardBackground or COLORS.Background
	Tab.BackgroundTransparency = isActive and 0 or 1
	Tab.Text = name
	Tab.TextColor3 = isActive and COLORS.TextPrimary or COLORS.TextMuted
	Tab.Font = Enum.Font.GothamBold
	Tab.TextSize = 11
	Tab.Parent = self.TopNavList

	local TabCorner = Instance.new("UICorner")
	TabCorner.CornerRadius = UDim.new(0, 6)
	TabCorner.Parent = Tab

	if isActive then
		local Line = Instance.new("Frame")
		Line.Size = UDim2.new(0, 18, 0, 3)
		Line.Position = UDim2.new(0.5, -9, 0, 2)
		Line.BackgroundColor3 = COLORS.Accent
		Line.BorderSizePixel = 0
		Line.Parent = Tab

		local LineCorner = Instance.new("UICorner")
		LineCorner.CornerRadius = UDim.new(1, 0)
		LineCorner.Parent = Line
	end

	if callback then
		Tab.MouseButton1Click:Connect(callback)
	end
	return Tab
end

