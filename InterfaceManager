local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local LocalPlayer = Players.LocalPlayer

local Library = {}
Library.__index = Library

function Library:CreateWindow(options)
    options = options or {}
    local windowTitle = options.Title or "JayHub"
    local windowSubTitle = options.SubTitle or "Grow a Garden 2"
    local windowVersion = options.Version or "v1.3.9 • Free"
    local accentColor = options.AccentColor or Color3.fromRGB(27, 78, 245)

    -- ScreenGui Setup
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = windowTitle .. "UI"
    screenGui.ResetOnSpawn = false

    local success, _ = pcall(function()
        screenGui.Parent = CoreGui
    end)
    if not success then
        screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
    end

    -- Main Container Frame
    local mainFrame = Instance.new("Frame")
    mainFrame.Name = "MainFrame"
    mainFrame.Size = UDim2.new(0, 680, 0, 420)
    mainFrame.Position = UDim2.new(0.5, -340, 0.5, -210)
    mainFrame.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
    mainFrame.BorderSizePixel = 0
    mainFrame.Active = true
    mainFrame.Draggable = true
    mainFrame.Parent = screenGui

    local mainCorner = Instance.new("UICorner")
    mainCorner.CornerRadius = UDim.new(0, 10)
    mainCorner.Parent = mainFrame

    local mainStroke = Instance.new("UIStroke")
    mainStroke.Color = Color3.fromRGB(45, 45, 55)
    mainStroke.Thickness = 1
    mainStroke.Parent = mainFrame

    -- Sidebar
    local sidebar = Instance.new("Frame")
    sidebar.Name = "Sidebar"
    sidebar.Size = UDim2.new(0, 160, 1, 0)
    sidebar.BackgroundColor3 = Color3.fromRGB(13, 13, 16)
    sidebar.BorderSizePixel = 0
    sidebar.Parent = mainFrame

    local sidebarCorner = Instance.new("UICorner")
    sidebarCorner.CornerRadius = UDim.new(0, 10)
    sidebarCorner.Parent = sidebar

    -- Header / Title
    local titleContainer = Instance.new("Frame")
    titleContainer.Size = UDim2.new(1, -20, 0, 50)
    titleContainer.Position = UDim2.new(0, 12, 0, 14)
    titleContainer.BackgroundTransparency = 1
    titleContainer.Parent = sidebar

    local mainTitleLabel = Instance.new("TextLabel")
    mainTitleLabel.Size = UDim2.new(1, 0, 0, 26)
    mainTitleLabel.BackgroundTransparency = 1
    mainTitleLabel.Font = Enum.Font.GothamBold
    mainTitleLabel.TextSize = 22
    mainTitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    mainTitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    mainTitleLabel.RichText = true
    
    local colorR, colorG, colorB = math.floor(accentColor.R * 255), math.floor(accentColor.G * 255), math.floor(accentColor.B * 255)
    mainTitleLabel.Text = string.format('<font color="rgb(%d,%d,%d)">%s</font>', colorR, colorG, colorB, windowTitle)
    mainTitleLabel.Parent = titleContainer

    local subTitleLabel = Instance.new("TextLabel")
    subTitleLabel.Size = UDim2.new(1, 0, 0, 16)
    subTitleLabel.Position = UDim2.new(0, 0, 0, 26)
    subTitleLabel.BackgroundTransparency = 1
    subTitleLabel.Font = Enum.Font.Gotham
    subTitleLabel.TextSize = 12
    subTitleLabel.TextColor3 = Color3.fromRGB(140, 140, 150)
    subTitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    subTitleLabel.Text = windowSubTitle
    subTitleLabel.Parent = titleContainer

    -- Navigation Container
    local tabContainer = Instance.new("Frame")
    tabContainer.Name = "TabContainer"
    tabContainer.Size = UDim2.new(1, -20, 1, -130)
    tabContainer.Position = UDim2.new(0, 10, 0, 70)
    tabContainer.BackgroundTransparency = 1
    tabContainer.Parent = sidebar

    local tabLayout = Instance.new("UIListLayout")
    tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
    tabLayout.Padding = UDim.new(0, 6)
    tabLayout.Parent = tabContainer

    -- User Status Panel
    local userProfile = Instance.new("Frame")
    userProfile.Size = UDim2.new(1, -16, 0, 36)
    userProfile.Position = UDim2.new(0, 8, 1, -46)
    userProfile.BackgroundColor3 = Color3.fromRGB(20, 20, 26)
    userProfile.Parent = sidebar

    local userCorner = Instance.new("UICorner")
    userCorner.CornerRadius = UDim.new(0, 6)
    userCorner.Parent = userProfile

    local avatarIcon = Instance.new("ImageLabel")
    avatarIcon.Size = UDim2.new(0, 26, 0, 26)
    avatarIcon.Position = UDim2.new(0, 5, 0.5, -13)
    avatarIcon.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
    avatarIcon.Parent = userProfile

    local avatarCorner = Instance.new("UICorner")
    avatarCorner.CornerRadius = UDim.new(1, 0)
    avatarCorner.Parent = avatarIcon

    task.spawn(function()
        if LocalPlayer then
            local content, isReady = Players:GetUserThumbnailAsync(
                LocalPlayer.UserId, 
                Enum.ThumbnailType.HeadShot, 
                Enum.ThumbnailSize.Size420x420
            )
            if isReady then
                avatarIcon.Image = content
            end
        end
    end)

    local keyStatusLabel = Instance.new("TextLabel")
    keyStatusLabel.Size = UDim2.new(1, -38, 1, 0)
    keyStatusLabel.Position = UDim2.new(0, 36, 0, 0)
    keyStatusLabel.BackgroundTransparency = 1
    keyStatusLabel.Font = Enum.Font.GothamMedium
    keyStatusLabel.TextSize = 12
    keyStatusLabel.TextColor3 = Color3.fromRGB(200, 200, 210)
    keyStatusLabel.TextXAlignment = Enum.TextXAlignment.Left
    keyStatusLabel.Text = "Lifetime Key"
    keyStatusLabel.Parent = userProfile

    -- Content Display Area
    local contentArea = Instance.new("Frame")
    contentArea.Name = "ContentArea"
    contentArea.Size = UDim2.new(1, -172, 1, -50)
    contentArea.Position = UDim2.new(0, 166, 0, 8)
    contentArea.BackgroundColor3 = Color3.fromRGB(24, 24, 30)
    contentArea.BorderSizePixel = 0
    contentArea.Parent = mainFrame

    local contentCorner = Instance.new("UICorner")
    contentCorner.CornerRadius = UDim.new(0, 8)
    contentCorner.Parent = contentArea

    local contentStroke = Instance.new("UIStroke")
    contentStroke.Color = Color3.fromRGB(38, 38, 48)
    contentStroke.Thickness = 1
    contentStroke.Parent = contentArea

    -- Footer Version Label
    local versionLabel = Instance.new("TextLabel")
    versionLabel.Size = UDim2.new(0, 120, 0, 24)
    versionLabel.Position = UDim2.new(1, -128, 1, -32)
    versionLabel.BackgroundTransparency = 1
    versionLabel.Font = Enum.Font.GothamMedium
    versionLabel.TextSize = 12
    versionLabel.TextColor3 = Color3.fromRGB(120, 120, 135)
    versionLabel.TextXAlignment = Enum.TextXAlignment.Right
    versionLabel.Text = windowVersion
    versionLabel.Parent = mainFrame

    -- Window Object
    local Window = {
        Tabs = {},
        ActiveTab = nil,
        ContentArea = contentArea,
        TabContainer = tabContainer,
        AccentColor = accentColor
    }

    function Window:CreateTab(tabName)
        local tabObj = {}
        
        -- Scrolling Frame for Tab Content
        local pageFrame = Instance.new("ScrollingFrame")
        pageFrame.Name = tabName .. "Page"
        pageFrame.Size = UDim2.new(1, -16, 1, -16)
        pageFrame.Position = UDim2.new(0, 8, 0, 8)
        pageFrame.BackgroundTransparency = 1
        pageFrame.BorderSizePixel = 0
        pageFrame.ScrollBarThickness = 4
        pageFrame.ScrollBarImageColor3 = Color3.fromRGB(50, 50, 65)
        pageFrame.Visible = false
        pageFrame.ClipsDescendants = true
        pageFrame.Parent = Window.ContentArea

        local pageLayout = Instance.new("UIListLayout")
        pageLayout.SortOrder = Enum.SortOrder.LayoutOrder
        pageLayout.Padding = UDim.new(0, 8)
        pageLayout.Parent = pageFrame

        local function updateCanvas()
            pageFrame.CanvasSize = UDim2.new(0, 0, 0, pageLayout.AbsoluteContentSize.Y + 16)
        end
        pageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas)

        -- Sidebar Tab Button
        local tabBtn = Instance.new("TextButton")
        tabBtn.Size = UDim2.new(1, 0, 0, 32)
        tabBtn.BackgroundColor3 = Window.AccentColor
        tabBtn.BackgroundTransparency = 1
        tabBtn.Font = Enum.Font.GothamMedium
        tabBtn.Text = "    " .. tabName
        tabBtn.TextColor3 = Color3.fromRGB(160, 160, 175)
        tabBtn.TextSize = 13
        tabBtn.TextXAlignment = Enum.TextXAlignment.Left
        tabBtn.Parent = Window.TabContainer

        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 6)
        btnCorner.Parent = tabBtn

        local function activateTab()
            for _, t in pairs(Window.Tabs) do
                t.Page.Visible = false
                t.Button.BackgroundTransparency = 1
                t.Button.TextColor3 = Color3.fromRGB(160, 160, 175)
            end
            pageFrame.Visible = true
            tabBtn.BackgroundTransparency = 0.85
            tabBtn.TextColor3 = Window.AccentColor
            Window.ActiveTab = tabObj
        end

        tabBtn.MouseButton1Click:Connect(activateTab)

        tabBtn.MouseEnter:Connect(function()
            if Window.ActiveTab ~= tabObj then
                TweenService:Create(tabBtn, TweenInfo.new(0.2), {
                    BackgroundTransparency = 0.92,
                    TextColor3 = Color3.fromRGB(220, 220, 230)
                }):Play()
            end
        end)

        tabBtn.MouseLeave:Connect(function()
            if Window.ActiveTab ~= tabObj then
                TweenService:Create(tabBtn, TweenInfo.new(0.2), {
                    BackgroundTransparency = 1,
                    TextColor3 = Color3.fromRGB(160, 160, 175)
                }):Play()
            end
        end)

        tabObj.Page = pageFrame
        tabObj.Button = tabBtn
        table.insert(Window.Tabs, tabObj)

        if #Window.Tabs == 1 then
            activateTab()
        end

        ----------------------------------------------------
        -- 1. BUTTON COMPONENT
        ----------------------------------------------------
        function tabObj:CreateButton(btnText, callback)
            callback = callback or function() end

            local actionBtn = Instance.new("TextButton")
            actionBtn.Size = UDim2.new(1, -6, 0, 36)
            actionBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 38)
            actionBtn.Font = Enum.Font.GothamMedium
            actionBtn.Text = btnText
            actionBtn.TextColor3 = Color3.fromRGB(220, 220, 230)
            actionBtn.TextSize = 13
            actionBtn.Parent = pageFrame

            local bCorner = Instance.new("UICorner")
            bCorner.CornerRadius = UDim.new(0, 6)
            bCorner.Parent = actionBtn

            local bStroke = Instance.new("UIStroke")
            bStroke.Color = Color3.fromRGB(45, 45, 58)
            bStroke.Thickness = 1
            bStroke.Parent = actionBtn

            actionBtn.MouseEnter:Connect(function()
                TweenService:Create(actionBtn, TweenInfo.new(0.15), {
                    BackgroundColor3 = Color3.fromRGB(38, 38, 48)
                }):Play()
            end)

            actionBtn.MouseLeave:Connect(function()
                TweenService:Create(actionBtn, TweenInfo.new(0.15), {
                    BackgroundColor3 = Color3.fromRGB(30, 30, 38)
                }):Play()
            end)

            actionBtn.MouseButton1Click:Connect(function()
                TweenService:Create(actionBtn, TweenInfo.new(0.08), {
                    Size = UDim2.new(1, -10, 0, 34)
                }):Play()
                task.wait(0.08)
                TweenService:Create(actionBtn, TweenInfo.new(0.08), {
                    Size = UDim2.new(1, -6, 0, 36)
                }):Play()

                pcall(callback)
            end)

            return actionBtn
        end

        ----------------------------------------------------
        -- 2. INPUT TEXT COMPONENT
        ----------------------------------------------------
        function tabObj:CreateInput(titleText, placeholderText, callback)
            callback = callback or function() end

            local inputFrame = Instance.new("Frame")
            inputFrame.Size = UDim2.new(1, -6, 0, 42)
            inputFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 38)
            inputFrame.Parent = pageFrame

            local iCorner = Instance.new("UICorner")
            iCorner.CornerRadius = UDim.new(0, 6)
            iCorner.Parent = inputFrame

            local iStroke = Instance.new("UIStroke")
            iStroke.Color = Color3.fromRGB(45, 45, 58)
            iStroke.Thickness = 1
            iStroke.Parent = inputFrame

            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(0.45, -12, 1, 0)
            label.Position = UDim2.new(0, 12, 0, 0)
            label.BackgroundTransparency = 1
            label.Font = Enum.Font.GothamMedium
            label.Text = titleText
            label.TextColor3 = Color3.fromRGB(220, 220, 230)
            label.TextSize = 13
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.Parent = inputFrame

            local textBox = Instance.new("TextBox")
            textBox.Size = UDim2.new(0.55, -12, 0, 28)
            textBox.Position = UDim2.new(0.45, 0, 0.5, -14)
            textBox.BackgroundColor3 = Color3.fromRGB(20, 20, 26)
            textBox.Font = Enum.Font.Gotham
            textBox.PlaceholderText = placeholderText or "Enter text..."
            textBox.PlaceholderColor3 = Color3.fromRGB(110, 110, 125)
            textBox.Text = ""
            textBox.TextColor3 = Color3.fromRGB(240, 240, 250)
            textBox.TextSize = 12
            textBox.ClearTextOnFocus = false
            textBox.Parent = inputFrame

            local boxCorner = Instance.new("UICorner")
            boxCorner.CornerRadius = UDim.new(0, 4)
            boxCorner.Parent = textBox

            local boxStroke = Instance.new("UIStroke")
            boxStroke.Color = Color3.fromRGB(45, 45, 55)
            boxStroke.Thickness = 1
            boxStroke.Parent = textBox

            textBox.Focused:Connect(function()
                TweenService:Create(boxStroke, TweenInfo.new(0.2), {
                    Color = Window.AccentColor
                }):Play()
            end)

            textBox.FocusLost:Connect(function(enterPressed)
                TweenService:Create(boxStroke, TweenInfo.new(0.2), {
                    Color = Color3.fromRGB(45, 45, 55)
                }):Play()
                pcall(callback, textBox.Text, enterPressed)
            end)

            return inputFrame
        end

        ----------------------------------------------------
        -- 3. DROPDOWN COMPONENT (SINGLE & MULTI SELECT)
        ----------------------------------------------------
        function tabObj:CreateDropdown(titleText, optionsList, defaultOption, isMultiSelect, callback)
            optionsList = optionsList or {}
            
            -- Rearrange arguments if isMultiSelect was omitted (backward compatibility)
            if type(isMultiSelect) == "function" then
                callback = isMultiSelect
                isMultiSelect = false
            end
            callback = callback or function() end

            local isOpen = false
            local selectedValues = {}

            -- Multi-Select or Single-Select Defaulting
            if isMultiSelect then
                if type(defaultOption) == "table" then
                    for _, val in ipairs(defaultOption) do
                        selectedValues[val] = true
                    end
                end
            else
                local initialVal = defaultOption or optionsList[1] or "Select..."
                selectedValues[initialVal] = true
            end

            local dropdownContainer = Instance.new("Frame")
            dropdownContainer.Size = UDim2.new(1, -6, 0, 42)
            dropdownContainer.BackgroundColor3 = Color3.fromRGB(30, 30, 38)
            dropdownContainer.ClipsDescendants = true
            dropdownContainer.Parent = pageFrame

            local dCorner = Instance.new("UICorner")
            dCorner.CornerRadius = UDim.new(0, 6)
            dCorner.Parent = dropdownContainer

            local dStroke = Instance.new("UIStroke")
            dStroke.Color = Color3.fromRGB(45, 45, 58)
            dStroke.Thickness = 1
            dStroke.Parent = dropdownContainer

            -- Top Toggle Button
            local headerBtn = Instance.new("TextButton")
            headerBtn.Size = UDim2.new(1, 0, 0, 42)
            headerBtn.BackgroundTransparency = 1
            headerBtn.Text = ""
            headerBtn.Parent = dropdownContainer

            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(0.5, -12, 1, 0)
            label.Position = UDim2.new(0, 12, 0, 0)
            label.BackgroundTransparency = 1
            label.Font = Enum.Font.GothamMedium
            label.Text = titleText
            label.TextColor3 = Color3.fromRGB(220, 220, 230)
            label.TextSize = 13
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.Parent = headerBtn

            local selectedLabel = Instance.new("TextLabel")
            selectedLabel.Size = UDim2.new(0.5, -28, 1, 0)
            selectedLabel.Position = UDim2.new(0.5, 0, 0, 0)
            selectedLabel.BackgroundTransparency = 1
            selectedLabel.Font = Enum.Font.Gotham
            selectedLabel.TextColor3 = Window.AccentColor
            selectedLabel.TextSize = 12
            selectedLabel.TextXAlignment = Enum.TextXAlignment.Right
            selectedLabel.Parent = headerBtn

            local arrowIcon = Instance.new("TextLabel")
            arrowIcon.Size = UDim2.new(0, 20, 1, 0)
            arrowIcon.Position = UDim2.new(1, -24, 0, 0)
            arrowIcon.BackgroundTransparency = 1
            arrowIcon.Font = Enum.Font.GothamBold
            arrowIcon.Text = "v"
            arrowIcon.TextColor3 = Color3.fromRGB(150, 150, 165)
            arrowIcon.TextSize = 12
            arrowIcon.Parent = headerBtn

            -- List Options Container
            local optionListFrame = Instance.new("Frame")
            optionListFrame.Size = UDim2.new(1, -16, 0, 0)
            optionListFrame.Position = UDim2.new(0, 8, 0, 42)
            optionListFrame.BackgroundTransparency = 1
            optionListFrame.Parent = dropdownContainer

            local listLayout = Instance.new("UIListLayout")
            listLayout.SortOrder = Enum.SortOrder.LayoutOrder
            listLayout.Padding = UDim.new(0, 4)
            listLayout.Parent = optionListFrame

            local function updateHeaderLabel()
                if isMultiSelect then
                    local list = {}
                    for opt, isSel in pairs(selectedValues) do
                        if isSel then
                            table.insert(list, tostring(opt))
                        end
                    end
                    if #list == 0 then
                        selectedLabel.Text = "None"
                    else
                        selectedLabel.Text = table.concat(list, ", ")
                    end
                else
                    local current = "Select..."
                    for opt, isSel in pairs(selectedValues) do
                        if isSel then current = tostring(opt) break end
                    end
                    selectedLabel.Text = current
                end
            end

            local function refreshList()
                -- Clear existing items
                for _, child in pairs(optionListFrame:GetChildren()) do
                    if child:IsA("TextButton") then
                        child:Destroy()
                    end
                end

                for idx, opt in ipairs(optionsList) do
                    local isSelected = selectedValues[opt] == true
                    local optBtn = Instance.new("TextButton")
                    optBtn.Size = UDim2.new(1, 0, 0, 28)
                    optBtn.BackgroundColor3 = isSelected and Color3.fromRGB(35, 35, 45) or Color3.fromRGB(22, 22, 28)
                    optBtn.Font = Enum.Font.Gotham
                    optBtn.Text = "    " .. (isSelected and (isMultiSelect and "✓ " or "") or "") .. tostring(opt)
                    optBtn.TextColor3 = isSelected and Window.AccentColor or Color3.fromRGB(180, 180, 195)
                    optBtn.TextSize = 12
                    optBtn.TextXAlignment = Enum.TextXAlignment.Left
                    optBtn.LayoutOrder = idx
                    optBtn.Parent = optionListFrame

                    local oCorner = Instance.new("UICorner")
                    oCorner.CornerRadius = UDim.new(0, 4)
                    oCorner.Parent = optBtn

                    optBtn.MouseButton1Click:Connect(function()
                        if isMultiSelect then
                            -- Toggle selection state
                            selectedValues[opt] = not selectedValues[opt]
                            updateHeaderLabel()
                            refreshList()

                            -- Extract list of currently selected items
                            local selectedTable = {}
                            for item, sel in pairs(selectedValues) do
                                if sel then table.insert(selectedTable, item) end
                            end

                            -- Auto adjust container size dynamically
                            if isOpen then
                                local listHeight = listLayout.AbsoluteContentSize.Y
                                dropdownContainer.Size = UDim2.new(1, -6, 0, 48 + listHeight)
                            end

                            pcall(callback, selectedTable)
                        else
                            -- Single selection
                            selectedValues = {[opt] = true}
                            updateHeaderLabel()
                            isOpen = false

                            TweenService:Create(dropdownContainer, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                                Size = UDim2.new(1, -6, 0, 42)
                            }):Play()
                            TweenService:Create(arrowIcon, TweenInfo.new(0.2), {Rotation = 0}):Play()

                            refreshList()
                            pcall(callback, opt)
                        end
                    end)
                end
            end

            updateHeaderLabel()
            refreshList()

            -- Toggle Open/Close
            headerBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                local listHeight = listLayout.AbsoluteContentSize.Y
                local targetHeight = isOpen and (48 + listHeight) or 42

                TweenService:Create(dropdownContainer, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                    Size = UDim2.new(1, -6, 0, targetHeight)
                }):Play()

                TweenService:Create(arrowIcon, TweenInfo.new(0.2), {
                    Rotation = isOpen and 180 or 0
                }):Play()
            end)

            return dropdownContainer
        end

        return tabObj
    end

    return Window
end

return Library
