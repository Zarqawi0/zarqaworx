local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local LocalPlayer = Players.LocalPlayer

local Library = {}
Library.__index = Library

function Library:CreateWindow(options)
    options = options or {}
    local windowTitle = options.Title or "JayHub"
    local windowSubTitle = options.SubTitle or "Grow a Garden 2"
    local windowVersion = options.Version or "v1.3.9 • Free"
    local accentColor = options.AccentColor or Color3.fromRGB(27, 78, 245)

    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = windowTitle .. "UI"
    screenGui.ResetOnSpawn = false

    local success, _ = pcall(function()
        screenGui.Parent = CoreGui
    end)
    if not success then
        screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
    end

    local mainFrame = Instance.new("Frame")
    mainFrame.Name = "MainFrame"
    mainFrame.Size = UDim2.new(0, 800, 0, 500)
    mainFrame.Position = UDim2.new(0.5, -400, 0.5, -250)
    mainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 18)
    mainFrame.BorderSizePixel = 0
    mainFrame.Active = true
    mainFrame.Parent = screenGui

    local mainCorner = Instance.new("UICorner")
    mainCorner.CornerRadius = UDim.new(0, 8)
    mainCorner.Parent = mainFrame

    local mainStroke = Instance.new("UIStroke")
    mainStroke.Color = Color3.fromRGB(30, 30, 38)
    mainStroke.Thickness = 1
    mainStroke.Parent = mainFrame

    local sidebar = Instance.new("Frame")
    sidebar.Name = "Sidebar"
    sidebar.Size = UDim2.new(0, 180, 1, 0)
    sidebar.BackgroundColor3 = Color3.fromRGB(11, 11, 14)
    sidebar.BorderSizePixel = 0
    sidebar.Parent = mainFrame

    local sidebarCorner = Instance.new("UICorner")
    sidebarCorner.CornerRadius = UDim.new(0, 8)
    sidebarCorner.Parent = sidebar

    local titleContainer = Instance.new("Frame")
    titleContainer.Name = "TitleContainer"
    titleContainer.Size = UDim2.new(1, -24, 0, 50)
    titleContainer.Position = UDim2.new(0, 12, 0, 14)
    titleContainer.BackgroundTransparency = 1
    titleContainer.Parent = sidebar

    local mainTitleLabel = Instance.new("TextLabel")
    mainTitleLabel.Size = UDim2.new(1, 0, 0, 26)
    mainTitleLabel.BackgroundTransparency = 1
    mainTitleLabel.Font = Enum.Font.GothamBold
    mainTitleLabel.TextSize = 22
    mainTitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    mainTitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    mainTitleLabel.RichText = true
    
    local colorR, colorG, colorB = math.floor(accentColor.R * 255), math.floor(accentColor.G * 255), math.floor(accentColor.B * 255)
    mainTitleLabel.Text = string.format('<font color="rgb(%d,%d,%d)">%s</font>', colorR, colorG, colorB, windowTitle)
    mainTitleLabel.Parent = titleContainer

    local subTitleLabel = Instance.new("TextLabel")
    subTitleLabel.Size = UDim2.new(1, 0, 0, 16)
    subTitleLabel.Position = UDim2.new(0, 0, 0, 26)
    subTitleLabel.BackgroundTransparency = 1
    subTitleLabel.Font = Enum.Font.Gotham
    subTitleLabel.TextSize = 12
    subTitleLabel.TextColor3 = Color3.fromRGB(120, 120, 130)
    subTitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    subTitleLabel.Text = windowSubTitle
    subTitleLabel.Parent = titleContainer

    -- Custom Dragging logic strictly bound to title header / sidebar area (White area is excluded)
    local dragging, dragInput, dragStart, startPos
    local function updateDrag(input)
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end

    sidebar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = mainFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    sidebar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            updateDrag(input)
        end
    end)

    local tabContainer = Instance.new("ScrollingFrame")
    tabContainer.Name = "TabContainer"
    tabContainer.Size = UDim2.new(1, -12, 1, -130)
    tabContainer.Position = UDim2.new(0, 6, 0, 70)
    tabContainer.BackgroundTransparency = 1
    tabContainer.BorderSizePixel = 0
    tabContainer.ScrollBarThickness = 3
    tabContainer.ScrollBarImageColor3 = Color3.fromRGB(40, 40, 52)
    tabContainer.ClipsDescendants = true
    tabContainer.CanvasSize = UDim2.new(0, 0, 0, 0)
    tabContainer.Parent = sidebar

    local tabLayout = Instance.new("UIListLayout")
    tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
    tabLayout.Padding = UDim.new(0, 6)
    tabLayout.Parent = tabContainer

    tabLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        tabContainer.CanvasSize = UDim2.new(0, 0, 0, tabLayout.AbsoluteContentSize.Y + 6)
    end)

    local userProfile = Instance.new("Frame")
    userProfile.Size = UDim2.new(1, -16, 0, 36)
    userProfile.Position = UDim2.new(0, 8, 1, -46)
    userProfile.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
    userProfile.ZIndex = 5
    userProfile.Parent = sidebar

    local userCorner = Instance.new("UICorner")
    userCorner.CornerRadius = UDim.new(0, 6)
    userCorner.Parent = userProfile

    local avatarIcon = Instance.new("ImageLabel")
    avatarIcon.Size = UDim2.new(0, 24, 0, 24)
    avatarIcon.Position = UDim2.new(0, 6, 0.5, -12)
    avatarIcon.BackgroundColor3 = Color3.fromRGB(30, 30, 38)
    avatarIcon.Parent = userProfile

    local avatarCorner = Instance.new("UICorner")
    avatarCorner.CornerRadius = UDim.new(1, 0)
    avatarCorner.Parent = avatarIcon

    task.spawn(function()
        if LocalPlayer then
            local content, isReady = Players:GetUserThumbnailAsync(
                LocalPlayer.UserId, 
                Enum.ThumbnailType.HeadShot, 
                Enum.ThumbnailSize.Size420x420
            )
            if isReady then
                avatarIcon.Image = content
            end
        end
    end)

    local keyStatusLabel = Instance.new("TextLabel")
    keyStatusLabel.Size = UDim2.new(1, -38, 1, 0)
    keyStatusLabel.Position = UDim2.new(0, 36, 0, 0)
    keyStatusLabel.BackgroundTransparency = 1
    keyStatusLabel.Font = Enum.Font.GothamMedium
    keyStatusLabel.TextSize = 12
    keyStatusLabel.TextColor3 = Color3.fromRGB(180, 180, 190)
    keyStatusLabel.TextXAlignment = Enum.TextXAlignment.Left
    keyStatusLabel.Text = "Lifetime Key"
    keyStatusLabel.Parent = userProfile

    -- Content Area fixed: Size reduced with 10% Opacity (0.9 Transparency)
    local contentArea = Instance.new("Frame")
    contentArea.Name = "ContentArea"
    contentArea.Size = UDim2.new(1, -210, 1, -56)
    contentArea.Position = UDim2.new(0, 195, 0, 14)
    contentArea.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
    contentArea.BackgroundTransparency = 0.9 -- Opacity 10%
    contentArea.BorderSizePixel = 0
    contentArea.ClipsDescendants = true
    contentArea.Parent = mainFrame

    local contentCorner = Instance.new("UICorner")
    contentCorner.CornerRadius = UDim.new(0, 8)
    contentCorner.Parent = contentArea

    local contentStroke = Instance.new("UIStroke")
    contentStroke.Color = Color3.fromRGB(28, 28, 35)
    contentStroke.Thickness = 1
    contentStroke.Parent = contentArea

    local versionLabel = Instance.new("TextLabel")
    versionLabel.Size = UDim2.new(0, 120, 0, 24)
    versionLabel.Position = UDim2.new(1, -128, 1, -28)
    versionLabel.BackgroundTransparency = 1
    versionLabel.Font = Enum.Font.GothamMedium
    versionLabel.TextSize = 12
    versionLabel.TextColor3 = Color3.fromRGB(100, 100, 115)
    versionLabel.TextXAlignment = Enum.TextXAlignment.Right
    versionLabel.Text = windowVersion
    versionLabel.Parent = mainFrame

    local Window = {
        Tabs = {},
        ActiveTab = nil,
        ContentArea = contentArea,
        TabContainer = tabContainer,
        AccentColor = accentColor
    }

    function Window:CreateTab(tabName)
        local tabObj = {}
        
        local pageFrame = Instance.new("ScrollingFrame")
        pageFrame.Name = tabName .. "Page"
        pageFrame.Size = UDim2.new(1, -16, 1, -16)
        pageFrame.Position = UDim2.new(0, 8, 0, 8)
        pageFrame.BackgroundTransparency = 1
        pageFrame.BorderSizePixel = 0
        pageFrame.ScrollBarThickness = 4
        pageFrame.ScrollBarImageColor3 = Color3.fromRGB(40, 40, 52)
        pageFrame.Visible = false
        pageFrame.ClipsDescendants = true
        pageFrame.Parent = Window.ContentArea

        local fullContainer = Instance.new("Frame")
        fullContainer.Name = "FullContainer"
        fullContainer.Size = UDim2.new(1, 0, 0, 0)
        fullContainer.BackgroundTransparency = 1
        fullContainer.Parent = pageFrame

        local fullLayout = Instance.new("UIListLayout")
        fullLayout.SortOrder = Enum.SortOrder.LayoutOrder
        fullLayout.Padding = UDim.new(0, 10)
        fullLayout.Parent = fullContainer

        local leftCol = Instance.new("Frame")
        leftCol.Name = "LeftColumn"
        leftCol.Size = UDim2.new(0.5, -6, 0, 0)
        leftCol.Position = UDim2.new(0, 0, 0, 0)
        leftCol.BackgroundTransparency = 1
        leftCol.Parent = pageFrame

        local leftLayout = Instance.new("UIListLayout")
        leftLayout.SortOrder = Enum.SortOrder.LayoutOrder
        leftLayout.Padding = UDim.new(0, 10)
        leftLayout.Parent = leftCol

        local rightCol = Instance.new("Frame")
        rightCol.Name = "RightColumn"
        rightCol.Size = UDim2.new(0.5, -6, 0, 0)
        rightCol.Position = UDim2.new(0.5, 6, 0, 0)
        rightCol.BackgroundTransparency = 1
        rightCol.Parent = pageFrame

        local rightLayout = Instance.new("UIListLayout")
        rightLayout.SortOrder = Enum.SortOrder.LayoutOrder
        rightLayout.Padding = UDim.new(0, 10)
        rightLayout.Parent = rightCol

        local function updateLayoutPositions()
            local fullH = fullLayout.AbsoluteContentSize.Y
            if fullH > 0 then fullH = fullH + 10 end

            leftCol.Position = UDim2.new(0, 0, 0, fullH)
            rightCol.Position = UDim2.new(0.5, 6, 0, fullH)

            local leftH = leftLayout.AbsoluteContentSize.Y
            local rightH = rightLayout.AbsoluteContentSize.Y
            local columnsMax = math.max(leftH, rightH)

            pageFrame.CanvasSize = UDim2.new(0, 0, 0, fullH + columnsMax + 14)
        end

        fullLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateLayoutPositions)
        leftLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateLayoutPositions)
        rightLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateLayoutPositions)

        local tabBtn = Instance.new("TextButton")
        tabBtn.Size = UDim2.new(1, -6, 0, 38)
        tabBtn.BackgroundColor3 = Window.AccentColor
        tabBtn.BackgroundTransparency = 1
        tabBtn.Font = Enum.Font.GothamMedium
        tabBtn.TextColor3 = Color3.fromRGB(150, 150, 165)
        tabBtn.TextSize = 14
        tabBtn.TextXAlignment = Enum.TextXAlignment.Left
        tabBtn.Text = tabName
        tabBtn.Parent = Window.TabContainer

        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 6)
        btnCorner.Parent = tabBtn

        local padding = Instance.new("UIPadding")
        padding.PaddingLeft = UDim.new(0, 14)
        padding.Parent = tabBtn

        local function activateTab()
            for _, t in pairs(Window.Tabs) do
                t.Page.Visible = false
                t.Button.BackgroundTransparency = 1
                t.Button.TextColor3 = Color3.fromRGB(150, 150, 165)
            end
            pageFrame.Visible = true
            tabBtn.BackgroundTransparency = 0.88
            tabBtn.TextColor3 = Window.AccentColor
            Window.ActiveTab = tabObj
        end

        tabBtn.MouseButton1Click:Connect(activateTab)

        tabBtn.MouseEnter:Connect(function()
            if Window.ActiveTab ~= tabObj then
                TweenService:Create(tabBtn, TweenInfo.new(0.15), {
                    BackgroundTransparency = 0.94,
                    TextColor3 = Color3.fromRGB(220, 220, 230)
                }):Play()
            end
        end)

        tabBtn.MouseLeave:Connect(function()
            if Window.ActiveTab ~= tabObj then
                TweenService:Create(tabBtn, TweenInfo.new(0.15), {
                    BackgroundTransparency = 1,
                    TextColor3 = Color3.fromRGB(150, 150, 165)
                }):Play()
            end
        end)

        tabObj.Page = pageFrame
        tabObj.Button = tabBtn
        table.insert(Window.Tabs, tabObj)

        if #Window.Tabs == 1 then
            activateTab()
        end

        local function getTargetParent(side)
            if side == "right" or side == 2 or side == "Right" then
                return rightCol
            elseif side == "full" or side == "Center" or side == "center" then
                return fullContainer
            else
                return leftCol
            end
        end

        ------------------------------------------------------------------------
        -- ELEMENT CREATORS
        ------------------------------------------------------------------------

        function tabObj:CreateButton(btnText, callback, side)
            callback = callback or function() end
            local parentCol = getTargetParent(side)

            local actionBtn = Instance.new("TextButton")
            actionBtn.Size = UDim2.new(1, 0, 0, 46)
            actionBtn.BackgroundColor3 = Color3.fromRGB(24, 24, 30)
            actionBtn.Font = Enum.Font.GothamMedium
            actionBtn.Text = btnText
            actionBtn.TextColor3 = Color3.fromRGB(210, 210, 220)
            actionBtn.TextSize = 14
            actionBtn.Parent = parentCol

            local bCorner = Instance.new("UICorner")
            bCorner.CornerRadius = UDim.new(0, 6)
            bCorner.Parent = actionBtn

            local bStroke = Instance.new("UIStroke")
            bStroke.Color = Color3.fromRGB(35, 35, 45)
            bStroke.Thickness = 1
            bStroke.Parent = actionBtn

            actionBtn.MouseEnter:Connect(function()
                TweenService:Create(actionBtn, TweenInfo.new(0.15), {
                    BackgroundColor3 = Color3.fromRGB(30, 30, 38)
                }):Play()
            end)

            actionBtn.MouseLeave:Connect(function()
                TweenService:Create(actionBtn, TweenInfo.new(0.15), {
                    BackgroundColor3 = Color3.fromRGB(24, 24, 30)
                }):Play()
            end)

            actionBtn.MouseButton1Click:Connect(function()
                pcall(callback)
            end)

            return actionBtn
        end

        function tabObj:CreateInput(titleText, placeholderText, callback, side)
            callback = callback or function() end
            local parentCol = getTargetParent(side)
            local savedPlaceholder = placeholderText or "Enter..."

            local inputFrame = Instance.new("Frame")
            inputFrame.Size = UDim2.new(1, 0, 0, 46)
            inputFrame.BackgroundColor3 = Color3.fromRGB(24, 24, 30)
            inputFrame.Parent = parentCol

            local iCorner = Instance.new("UICorner")
            iCorner.CornerRadius = UDim.new(0, 6)
            iCorner.Parent = inputFrame

            local iStroke = Instance.new("UIStroke")
            iStroke.Color = Color3.fromRGB(35, 35, 45)
            iStroke.Thickness = 1
            iStroke.Parent = inputFrame

            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(0.45, -10, 1, 0)
            label.Position = UDim2.new(0, 12, 0, 0)
            label.BackgroundTransparency = 1
            label.Font = Enum.Font.GothamMedium
            label.Text = titleText
            label.TextColor3 = Color3.fromRGB(210, 210, 220)
            label.TextSize = 13
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.Parent = inputFrame

            local textBox = Instance.new("TextBox")
            textBox.Size = UDim2.new(0.55, -12, 0, 30)
            textBox.Position = UDim2.new(0.45, 0, 0.5, -15)
            textBox.BackgroundColor3 = Color3.fromRGB(16, 16, 20)
            textBox.Font = Enum.Font.Gotham
            textBox.PlaceholderText = savedPlaceholder
            textBox.PlaceholderColor3 = Color3.fromRGB(150, 150, 165)
            textBox.Text = ""
            textBox.TextColor3 = Color3.fromRGB(255, 255, 255)
            textBox.TextSize = 13
            textBox.ClearTextOnFocus = false
            textBox.Parent = inputFrame

            local boxCorner = Instance.new("UICorner")
            boxCorner.CornerRadius = UDim.new(0, 4)
            boxCorner.Parent = textBox

            local boxStroke = Instance.new("UIStroke")
            boxStroke.Color = Color3.fromRGB(35, 35, 45)
            boxStroke.Thickness = 1
            boxStroke.Parent = textBox

            -- Clears Placeholder on Click/Focus (Image 3 Fix)
            textBox.Focused:Connect(function()
                textBox.PlaceholderText = ""
                TweenService:Create(boxStroke, TweenInfo.new(0.15), {
                    Color = Window.AccentColor
                }):Play()
            end)

            textBox.FocusLost:Connect(function(enterPressed)
                if textBox.Text == "" then
                    textBox.PlaceholderText = savedPlaceholder
                end
                TweenService:Create(boxStroke, TweenInfo.new(0.15), {
                    Color = Color3.fromRGB(35, 35, 45)
                }):Play()
                pcall(callback, textBox.Text, enterPressed)
            end)

            return inputFrame
        end

        function tabObj:CreateSlider(titleText, minVal, maxVal, defaultVal, callback, side)
            callback = callback or function() end
            minVal = minVal or 0
            maxVal = maxVal or 100
            defaultVal = math.clamp(defaultVal or minVal, minVal, maxVal)

            local parentCol = getTargetParent(side)
            local currentVal = defaultVal

            local sliderContainer = Instance.new("Frame")
            sliderContainer.Size = UDim2.new(1, 0, 0, 52)
            sliderContainer.BackgroundColor3 = Color3.fromRGB(24, 24, 30)
            sliderContainer.Parent = parentCol

            local sCorner = Instance.new("UICorner")
            sCorner.CornerRadius = UDim.new(0, 6)
            sCorner.Parent = sliderContainer

            local sStroke = Instance.new("UIStroke")
            sStroke.Color = Color3.fromRGB(35, 35, 45)
            sStroke.Thickness = 1
            sStroke.Parent = sliderContainer

            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(0.6, -12, 0, 24)
            label.Position = UDim2.new(0, 12, 0, 6)
            label.BackgroundTransparency = 1
            label.Font = Enum.Font.GothamMedium
            label.Text = titleText
            label.TextColor3 = Color3.fromRGB(210, 210, 220)
            label.TextSize = 13
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.Parent = sliderContainer

            local valInput = Instance.new("TextBox")
            valInput.Size = UDim2.new(0, 56, 0, 22)
            valInput.Position = UDim2.new(1, -68, 0, 6)
            valInput.BackgroundColor3 = Color3.fromRGB(16, 16, 20)
            valInput.Font = Enum.Font.Gotham
            valInput.Text = tostring(currentVal)
            valInput.TextColor3 = Color3.fromRGB(255, 255, 255) -- White Font (Image 2 Fix)
            valInput.TextSize = 12
            valInput.ClearTextOnFocus = false
            valInput.Parent = sliderContainer

            local valCorner = Instance.new("UICorner")
            valCorner.CornerRadius = UDim.new(0, 4)
            valCorner.Parent = valInput

            local valStroke = Instance.new("UIStroke")
            valStroke.Color = Color3.fromRGB(35, 35, 45)
            valStroke.Thickness = 1
            valStroke.Parent = valInput

            local sliderBar = Instance.new("Frame")
            sliderBar.Size = UDim2.new(1, -24, 0, 6)
            sliderBar.Position = UDim2.new(0, 12, 0, 36)
            sliderBar.BackgroundColor3 = Color3.fromRGB(16, 16, 20)
            sliderBar.Parent = sliderContainer

            local barCorner = Instance.new("UICorner")
            barCorner.CornerRadius = UDim.new(1, 0)
            barCorner.Parent = sliderBar

            local fill = Instance.new("Frame")
            fill.Size = UDim2.new((currentVal - minVal) / (maxVal - minVal), 0, 1, 0)
            fill.BackgroundColor3 = Window.AccentColor
            fill.Parent = sliderBar

            local fillCorner = Instance.new("UICorner")
            fillCorner.CornerRadius = UDim.new(1, 0)
            fillCorner.Parent = fill

            local knob = Instance.new("Frame")
            knob.Size = UDim2.new(0, 14, 0, 14)
            knob.AnchorPoint = Vector2.new(0.5, 0.5)
            knob.Position = UDim2.new((currentVal - minVal) / (maxVal - minVal), 0, 0.5, 0)
            knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            knob.Parent = sliderBar

            local knobCorner = Instance.new("UICorner")
            knobCorner.CornerRadius = UDim.new(1, 0)
            knobCorner.Parent = knob

            local isDragging = false

            local function updateValue(input)
                local posX = math.clamp(input.Position.X - sliderBar.AbsolutePosition.X, 0, sliderBar.AbsoluteSize.X)
                local percent = posX / sliderBar.AbsoluteSize.X
                currentVal = math.floor(minVal + (maxVal - minVal) * percent)

                valInput.Text = tostring(currentVal)
                fill.Size = UDim2.new(percent, 0, 1, 0)
                knob.Position = UDim2.new(percent, 0, 0.5, 0)
                pcall(callback, currentVal)
            end

            valInput.Focused:Connect(function()
                TweenService:Create(valStroke, TweenInfo.new(0.15), {
                    Color = Window.AccentColor
                }):Play()
            end)

            valInput.FocusLost:Connect(function()
                TweenService:Create(valStroke, TweenInfo.new(0.15), {
                    Color = Color3.fromRGB(35, 35, 45)
                }):Play()
                local num = tonumber(valInput.Text)
                if num then
                    currentVal = math.clamp(math.floor(num), minVal, maxVal)
                end
                valInput.Text = tostring(currentVal)
                local percent = (currentVal - minVal) / (maxVal - minVal)
                fill.Size = UDim2.new(percent, 0, 1, 0)
                knob.Position = UDim2.new(percent, 0, 0.5, 0)
                pcall(callback, currentVal)
            end)

            sliderBar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    isDragging = true
                    updateValue(input)
                end
            end)

            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    isDragging = false
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    updateValue(input)
                end
            end)

            return sliderContainer
        end

        return tabObj
    end

    return Window
end

return Library
