            local switchBtn = Instance.new("TextButton")
            switchBtn.Size = UDim2.new(0, 36, 0, 18)
            switchBtn.Position = UDim2.new(1, -44, 0.5, -9)
            switchBtn.BackgroundColor3 = toggled and Window.AccentColor or Color3.fromRGB(16, 16, 20)
            switchBtn.Text = ""
            switchBtn.Parent = toggleContainer

            local switchCorner = Instance.new("UICorner")
            switchCorner.CornerRadius = UDim.new(1, 0)
            switchCorner.Parent = switchBtn

            local circle = Instance.new("Frame")
            circle.Size = UDim2.new(0, 14, 0, 14)
            circle.Position = toggled and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
            circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            circle.Parent = switchBtn

            local circleCorner = Instance.new("UICorner")
            circleCorner.CornerRadius = UDim.new(1, 0)
            circleCorner.Parent = circle

            local function updateToggle()
                local targetBg = toggled and Window.AccentColor or Color3.fromRGB(16, 16, 20)
                local targetPos = toggled and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)

                TweenService:Create(switchBtn, TweenInfo.new(0.2), {BackgroundColor3 = targetBg}):Play()
                TweenService:Create(circle, TweenInfo.new(0.2), {Position = targetPos}):Play()
            end

            local clickOverlay = Instance.new("TextButton")
            clickOverlay.Size = UDim2.new(1, 0, 1, 0)
            clickOverlay.BackgroundTransparency = 1
            clickOverlay.Text = ""
            clickOverlay.Parent = toggleContainer

            clickOverlay.MouseButton1Click:Connect(function()
                toggled = not toggled
                updateToggle()
                pcall(callback, toggled)
            end)

            return toggleContainer
        end

        function tabObj:CreateParagraph(titleText, contentText, side)
            local parentCol = getTargetParent(side)

            local paraFrame = Instance.new("Frame")
            paraFrame.Size = UDim2.new(1, 0, 0, 0)
            paraFrame.BackgroundColor3 = Color3.fromRGB(24, 24, 30)
