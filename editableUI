                    searchDisplayText.Text = "|"
                    searchDisplayText.TextColor3 = Color3.fromRGB(255, 255, 255)
                end
                TweenService:Create(searchStroke, TweenInfo.new(0.15), {
                    Color = Window.AccentColor
                }):Play()
            end)
            searchInput.FocusLost:Connect(function()
                if searchInput.Text == "" then
                    searchDisplayText.Text = "Search..."
                    searchDisplayText.TextColor3 = Color3.fromRGB(90, 90, 105)
                else
                    searchDisplayText.Text = searchInput.Text
                    searchDisplayText.TextColor3 = Color3.fromRGB(230, 230, 240)
                end
                TweenService:Create(searchStroke, TweenInfo.new(0.15), {
                    Color = Color3.fromRGB(35, 35, 45)
                }):Play()
            end)
            searchInput:GetPropertyChangedSignal("Text"):Connect(function()
                if searchInput:IsFocused() then
                    if searchInput.Text == "" then
                        searchDisplayText.Text = "|"
                    else
                        searchDisplayText.Text = searchInput.Text .. "|"
                    end
                    searchDisplayText.TextColor3 = Color3.fromRGB(255, 255, 255)
                end
            end)

            local optionListFrame = Instance.new("Frame")
            optionListFrame.Size = UDim2.new(1, -16, 0, 0)
            optionListFrame.Position = UDim2.new(0, 8, 0, 96)
            optionListFrame.BackgroundTransparency = 1
            optionListFrame.ZIndex = 10
            optionListFrame.Parent = dropdownContainer

            local listLayout = Instance.new("UIListLayout")
            listLayout.SortOrder = Enum.SortOrder.LayoutOrder
            listLayout.Padding = UDim.new(0, 4)
            listLayout.Parent = optionListFrame

            local function updateHeaderLabel()
                if isMultiSelect then
                    local list = {}
                    for opt, isSel in pairs(selectedValues) do
                        if isSel then table.insert(list, tostring(opt)) end
                    end
                    selectedLabel.Text = (#list == 0) and "None" or table.concat(list, ", ")
                else
                    local current = "None"
                    for opt, isSel in pairs(selectedValues) do
                        if isSel then current = tostring(opt) break end
                    end
                    selectedLabel.Text = current
                end
            end

            local function updateContainerHeight()
                local listHeight = listLayout.AbsoluteContentSize.Y
                local targetHeight = isOpen and (104 + listHeight) or 52

                TweenService:Create(dropdownContainer, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                    Size = UDim2.new(1, 0, 0, targetHeight)
                }):Play()

                TweenService:Create(arrowIcon, TweenInfo.new(0.2), {
                    Rotation = isOpen and 180 or 0
                }):Play()
            end

            local function refreshList()
                for _, child in pairs(optionListFrame:GetChildren()) do
                    if child:IsA("TextButton") then child:Destroy() end
                end

                for idx, opt in ipairs(optionsList) do
                    local strOpt = tostring(opt)
                    if searchQuery == "" or string.find(string.lower(strOpt), string.lower(searchQuery), 1, true) then
                        local isSelected = selectedValues[opt] == true
                        local optBtn = Instance.new("TextButton")
                        optBtn.Size = UDim2.new(1, 0, 0, 32)
                        optBtn.BackgroundColor3 = isSelected and Window.AccentColor or Color3.fromRGB(18, 18, 22)
                        optBtn.BackgroundTransparency = isSelected and 0.88 or 0
                        applyFont(optBtn, Enum.FontWeight.Regular)
                        optBtn.Text = "   " .. (isSelected and "• " or "") .. strOpt
                        optBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
                        optBtn.TextSize = 13
                        optBtn.TextXAlignment = Enum.TextXAlignment.Left
                        optBtn.LayoutOrder = idx
                        optBtn.ZIndex = 11
                        optBtn.Parent = optionListFrame

                        local oCorner = Instance.new("UICorner")
                        oCorner.CornerRadius = UDim.new(0, 4)
                        oCorner.Parent = optBtn

                        optBtn.MouseButton1Click:Connect(function()
                            if isMultiSelect then
                                selectedValues[opt] = not selectedValues[opt]
                                updateHeaderLabel()
                                refreshList()
                                updateContainerHeight()

                                local selectedTable = {}
                                for item, sel in pairs(selectedValues) do
                                    if sel then table.insert(selectedTable, item) end
                                end
                                pcall(callback, selectedTable)
                            else
                                if selectedValues[opt] then
                                    selectedValues = {}
                                else
                                    selectedValues = {[opt] = true}
                                end
                                updateHeaderLabel()
                                refreshList()
                                updateContainerHeight()

                                local currentSelected = nil
                                for item, sel in pairs(selectedValues) do
                                    if sel then currentSelected = item break end
                                end
                                pcall(callback, currentSelected)
                            end
                        end)
                    end
                end
            end

            searchInput:GetPropertyChangedSignal("Text"):Connect(function()
                searchQuery = searchInput.Text
                refreshList()
                updateContainerHeight()
            end)

            updateHeaderLabel()
            refreshList()

            headerBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                updateContainerHeight()
            end)

            local DropdownController = {
                Instance = dropdownContainer
            }

            function DropdownController:SetTitle(newTitle)
                label.Text = tostring(newTitle)
            end

            function DropdownController:SetOptions(newList, newDefault)
                optionsList = newList or {}
                selectedValues = {}
                if isMultiSelect then
                    if type(newDefault) == "table" then
                        for _, val in ipairs(newDefault) do selectedValues[val] = true end
                    end
                else
                    if newDefault then selectedValues[newDefault] = true end
                end
                updateHeaderLabel()
                refreshList()
                updateContainerHeight()
            end

            function DropdownController:Refresh()
                refreshList()
                updateContainerHeight()
            end

            return DropdownController
        end

