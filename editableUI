                TweenService:Create(switchBtn, TweenInfo.new(0.2), {BackgroundColor3 = targetBg}):Play()
                TweenService:Create(circle, TweenInfo.new(0.2), {Position = targetPos}):Play()
            end

            local clickOverlay = Instance.new("TextButton")
            clickOverlay.Size = UDim2.new(1, 0, 1, 0)
            clickOverlay.BackgroundTransparency = 1
            clickOverlay.Text = ""
            clickOverlay.Parent = toggleContainer

            clickOverlay.MouseButton1Click:Connect(function()
                toggled = not toggled
                updateToggle()
                pcall(callback, toggled)
            end)

            return toggleContainer
        end

