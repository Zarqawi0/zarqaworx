                t.Button.BackgroundColor3 = Color3.fromRGB(11, 11, 14)
                t.Button.BackgroundTransparency = 1
                t.Button.TextColor3 = Color3.fromRGB(150, 150, 165)
                t.Icon.ImageColor3 = Color3.fromRGB(150, 150, 165)
