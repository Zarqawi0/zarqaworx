local FONT_FAMILY = "rbxassetid://12187365364" -- Inter font asset ID proxy for Roblox

local function applyFont(instance, weight, style)
    style = style or Enum.FontStyle.Normal
    if instance:IsA("TextLabel") or instance:IsA("TextButton") or instance:IsA("TextBox") then
        instance.FontFace = Font.new(FONT_FAMILY, weight, style)
    end
end

