local function updateVoidState()
    if BlackFrame.Visible then
        Camera.CameraType = Enum.CameraType.Scriptable
        Camera.CFrame = VoidPosition
        if not CameraConnection then
            CameraConnection = RS.RenderStepped:Connect(function()
                Camera.CFrame = VoidPosition
            end)
        end
        
        -- Activate the local safety floor to catch the moving macro player if chunks unload
        SafetyFloor.CanCollide = true
        if not FloorConnection then
            FloorConnection = RS.Heartbeat:Connect(function()
                local char = LP.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                if root then
                    SafetyFloor.CFrame = CFrame.new(root.Position.X, root.Position.Y - 3.6, root.Position.Z)
                end
            end)
        end
        
        pcall(function() RS:Set3dRenderingEnabled(false) end)
    else
        if CameraConnection then
            CameraConnection:Disconnect()
            CameraConnection = nil
        end
        if FloorConnection then
            FloorConnection:Disconnect()
            FloorConnection = nil
        end
        
        SafetyFloor.CanCollide = false
        Camera.CameraType = Enum.CameraType.Custom
        if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
            Camera.CameraSubject = LP.Character.Humanoid
        end
        pcall(function() RS:Set3dRenderingEnabled(true) end)
    end
end

task.spawn(function()
    task.wait(0.5)
    updateVoidState()
end)

ToggleButton.MouseButton1Click:Connect(function()
    BlackFrame.Visible = not BlackFrame.Visible
    updateVoidState()
end)
