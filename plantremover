-- ---------- LIGHTING & SHADOW HARD LOCK ----------
local function lockLighting()
    LT.GlobalShadows = false
    pcall(function() LT.Technology = Enum.Technology.Compatibility end)
    pcall(function() LT.FogStart, LT.FogEnd = 100000, 100000 end)
end
lockLighting()
LT:GetPropertyChangedSignal("GlobalShadows"):Connect(lockLighting)

-- ---------- TRANSPARENCY HARD-LOCK LISTENER ----------
local function forceInvisibleLock(part)
    part.Transparency = 1
    pcall(function()
        part.Material = Enum.Material.SmoothPlastic
        part.CastShadow = false
    end)
    
    local connection
    connection = part:GetPropertyChangedSignal("Transparency"):Connect(function()
        if not part or not part.Parent then
            connection:Disconnect()
            return
        end
        if part.Transparency < 1 then
            part.Transparency = 1
        end
    end)
end

-- ---------- GLOBAL ANTI-LAG ENGINE ----------
local function wipeLagSpecs(obj)
    if obj:IsDescendantOf(LP.Character) or obj == SafetyFloor then return end
    local name = obj.Name:lower()

    if obj:IsA("Highlight") or obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("Light") or obj:IsA("Animation") or obj:IsA("AnimationTrack") then
        pcall(function() obj:Destroy() end)
        return
    end

    if obj:IsA("Decal") or obj:IsA("Texture") or obj:IsA("SurfaceAppearance") then
        pcall(function() obj:Destroy() end)
        return
    end

    if obj:IsA("MeshPart") or obj:IsA("BasePart") then
        if name ~= "terrain" and not name:find("floor") and not name:find("ground") then
            forceInvisibleLock(obj)
        end
    end
end

workspace.DescendantAdded:Connect(wipeLagSpecs)

task.spawn(function()
    while true do
        local descendants = workspace:GetDescendants()
        for i = 1, #descendants do
            local obj = descendants[i]
            if obj and obj.Parent then
                wipeLagSpecs(obj)
            end
            if i % 150 == 0 then
                task.wait()
            end
        end
        task.wait(0.2)
    end
end)
